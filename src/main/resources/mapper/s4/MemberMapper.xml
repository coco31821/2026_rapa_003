<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="mapper.s4.MemberMapper">

    <!--
        컬럼과 필드를 명시적으로 연결하는 매핑 설정
    -->
    <resultMap id="memberDTOResultMap" type="domain.MemberDTO">
        <!--  id property는 식별에 도와준담. 관례적으로 column에 id를 나눠서 쓴담
         그래야 mybatis도 어떤 id인지 확실하게 구별가능하담      -->
        <id property="memberId" column="member_id"/>


        <result property="memberName" column="member_name"/>

        <result property="memberBalance" column="member_balance"/>
    </resultMap>


    <select id="findAll" resultMap="memberDTOResultMap">
        SELECT
            id AS member_id,
            name AS member_name,
            balance AS member_balance
        FROM
            member
    </select>

    <select id="findById" parameterType="long" resultType="domain.Member">
        SELECT
            id,
            name,
            email,
            balance
        FROM
            member
        WHERE
            id = #{id}
    </select>













</mapper>